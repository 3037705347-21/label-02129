# 环境变量配置示例
# 复制此文件为 .env.local 并根据需要修改

# API 配置
VITE_GEO_API_URL=https://geocoding-api.open-meteo.com/v1
VITE_WEATHER_API_URL=https://api.open-meteo.com/v1
VITE_API_TIMEOUT=10000

# 搜索配置
VITE_SEARCH_DEBOUNCE=300
VITE_SEARCH_MAX_RESULTS=10
VITE_MAX_HISTORY=10

# 缓存配置
VITE_WEATHER_CACHE_TTL=300000
VITE_ENABLE_CACHE=true

# 应用配置
VITE_APP_NAME=天气预报
